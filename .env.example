# Copy this file per environment:
#   cp .env.example .env.test   (dev: CORTEX_ENV_FILE=.env.test uvicorn ...)
#   cp .env.example .env.prod   (prod: docker-compose env_file)
# Every var below has a safe default in app/config.py — CORTEX runs fully
# keyless with this file absent or empty (golden rule #3).

DB_PATH=cortex.db

# ── Anthropic (empty ANTHROPIC_API_KEY ⇒ regex heuristic triage, no cost) ────
ANTHROPIC_API_KEY=
MODEL_FAST=claude-haiku-4-5-20251001
MODEL_SMART=claude-sonnet-4-6

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALLOWED_CHAT_IDS=
PUBLIC_BASE_URL=

# ── Loop A schedule ───────────────────────────────────────────────────────
BRIEF_HOUR=7
WEEKLY_REVIEW_DAY=sun
WEEKLY_REVIEW_HOUR=18

# ── Brief routing ─────────────────────────────────────────────────────────
STALE_DAYS=30
RECENT_ITEMS_FOR_DEDUP=40

TZ=Europe/Prague

# ── Dashboard auth (empty DASHBOARD_PASSWORD ⇒ auth disabled, keyless) ────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
SESSION_SECRET=

# ── Compose-only (production, Hostinger + Traefik) ───────────────────────
DOMAIN_NAME=
SSL_EMAIL=
